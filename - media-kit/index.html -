<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>QuietAscend Media Kit</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --qa-black: #050505;
      --qa-gold: #D4AF37;
      --qa-gray: #B3B3B3;
    }
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      background-color: var(--qa-black);
      color: #ffffff;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 16px;
    }
    .frame {
      max-width: 720px;
      width: 100%;
      border-top: 1px solid var(--qa-gold);
      padding-top: 32px;
    }
    .label {
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 11px;
      color: var(--qa-gray);
      margin-bottom: 12px;
    }
    h1 {
      font-size: 32px;
      line-height: 1.2;
      margin-bottom: 12px;
    }
    p {
      font-size: 15px;
      line-height: 1.6;
      color: var(--qa-gray);
      margin-bottom: 28px;
      max-width: 560px;
    }
    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 22px;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      border: 1px solid var(--qa-gold);
      background-color: var(--qa-gold);
      color: #050505;
    }
    .button.secondary {
      background-color: transparent;
      color: #ffffff;
      border-color: #333333;
    }
    .meta {
      margin-top: 18px;
      font-size: 12px;
      color: #777777;
    }
    @media (max-width: 480px) {
      h1 {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <main class="frame">
    <div class="label">QuietAscend · Media</div>
    <h1>QuietAscend Media Kit</h1>
    <p>
      A concise overview of QuietAscend’s audience, positioning, and partnership philosophy—built for SaaS teams and thoughtful brands who value clarity over noise.
    </p>
    <div class="button-row">
      <a class="button" href="QuietAscend-Media-Kit.pdf" target="_blank" rel="noopener">
        Download Media Kit (PDF)
      </a>
      <a class="button secondary" href="https://quietascend.com" target="_blank" rel="noopener">
        Visit QuietAscend.com
      </a>
    </div>
    <div class="meta">
      Last updated: <!-- you can manually update this date when you revise the kit -->
      Quiet, disciplined growth. No hype.
    </div>
  </main>
</body>
</html>
